{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vlbmx-chat",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.sql"]
    }
  ],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_ROOM",
        "class_name": "ChatRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom"]
    }
  ]
}
